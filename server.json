{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Darko893/mcp-server",
  "description": "MCP web extraction for Claude and Cursor: turn any URL into structured JSON with Haunt API",
  "repository": {
    "url": "https://github.com/Darko893/mcp-server",
    "source": "github"
  },
  "version": "1.0.3",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@hauntapi/mcp-server",
      "version": "1.0.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Haunt API key from https://hauntapi.com",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "HAUNT_API_KEY"
        }
      ]
    }
  ]
}